{
  "name": "twincat-ads",
  "version": "0.2.2",
  "description": "Monorepo for TwinCAT ADS core, Pi extension, and MCP server packages.",
  "author": "Niklas W",
  "license": "MIT",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "twincat",
    "ads",
    "beckhoff",
    "plc",
    "mcp",
    "pi-package"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Auda29/twincat-ads.git"
  },
  "homepage": "https://github.com/Auda29/twincat-ads#readme",
  "bugs": {
    "url": "https://github.com/Auda29/twincat-ads/issues"
  },
  "scripts": {
    "build": "tsc -b",
    "check": "tsc -b --pretty false",
    "test": "npm run test -w twincat-ads-core && npm run test -w pi-twincat-ads",
    "smoke:local": "node ./packages/pi/scripts/local-dev-smoke.mjs",
    "prepublishOnly": "npm run check && npm test && npm run build"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.67.3",
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^22.13.10",
    "ads-client": "^2.2.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8",
    "zod": "^3.24.2"
  }
}
