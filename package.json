{
  "name": "twincat-mcp-monorepo",
  "version": "0.3.0",
  "description": "Official TwinCAT MCP monorepo for ADS core, Pi extension, and MCP server packages.",
  "author": "Niklas W",
  "license": "MIT",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "twincat",
    "ads",
    "beckhoff",
    "plc",
    "mcp",
    "pi-package"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Auda29/twincat-mcp-mono.git"
  },
  "homepage": "https://github.com/Auda29/twincat-mcp-mono#readme",
  "bugs": {
    "url": "https://github.com/Auda29/twincat-mcp-mono/issues"
  },
  "scripts": {
    "build": "tsc -b",
    "check": "tsc -b --pretty false",
    "check:workspace": "node ./scripts/check-workspace-integration.mjs",
    "test": "npm run test:core && npm run test:pi && npm run test:mcp",
    "test:core": "npm run test -w twincat-mcp-core",
    "test:pi": "npm run test -w pi-twincat-ads",
    "test:mcp": "npm run test -w twincat-mcp",
    "pack:dry-run": "npm run pack:core && npm run pack:pi && npm run pack:mcp",
    "pack:core": "npm pack --dry-run -w twincat-mcp-core",
    "pack:pi": "npm pack --dry-run -w pi-twincat-ads",
    "pack:mcp": "npm pack --dry-run -w twincat-mcp",
    "smoke:local": "npm run smoke:local -w pi-twincat-ads --",
    "prepublishOnly": "npm run check && npm run check:workspace && npm test && npm run build && npm run pack:dry-run"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.67.3",
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^22.13.10",
    "ads-client": "^2.2.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8",
    "zod": "^3.24.2"
  }
}
