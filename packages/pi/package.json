{
  "name": "pi-twincat-ads",
  "version": "0.4.6",
  "description": "Pi extension for reading and writing TwinCAT runtime values over ADS.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Auda29/twincat-mcp-mono.git",
    "directory": "packages/pi"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pi-extension": {
      "types": "./dist/pi-extension.d.ts",
      "import": "./dist/pi-extension.js"
    }
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "keywords": [
    "pi-package",
    "twincat",
    "ads",
    "beckhoff",
    "plc"
  ],
  "pi": {
    "extensions": [
      "./dist/pi-extension.js"
    ],
    "skills": [
      "./skills"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "check": "tsc -b --pretty false",
    "test": "vitest run",
    "smoke:local": "node ./scripts/local-dev-smoke.mjs",
    "prepublishOnly": "npm run check && npm test && npm run build"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.67.3",
    "@sinclair/typebox": "^0.34.49",
    "twincat-mcp-core": "0.4.6",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
