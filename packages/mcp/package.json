{
  "name": "twincat-ads-mcp",
  "version": "0.1.0",
  "description": "MCP stdio server for TwinCAT ADS operations.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "twincat-ads-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "check": "tsc -b --pretty false",
    "test": "vitest run",
    "prepack": "node ../../scripts/pack-workspace-manifest.mjs prepare",
    "postpack": "node ../../scripts/pack-workspace-manifest.mjs restore"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "twincat-ads-core": "workspace:*",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  }
}
