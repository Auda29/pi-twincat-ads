{
  "name": "twincat-mcp",
  "version": "0.4.7",
  "description": "MCP stdio server for TwinCAT ADS operations.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Auda29/twincat-mcp-mono.git",
    "directory": "packages/mcp"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "twincat-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "check": "tsc -b --pretty false",
    "test": "vitest run",
    "sync:skills": "node ../../scripts/sync-package-skills.mjs --package mcp",
    "prepack": "npm run sync:skills",
    "postpack": "node ../../scripts/sync-package-skills.mjs --package mcp --clean"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "twincat-mcp-core": "0.4.7",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  }
}
