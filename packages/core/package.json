{
  "name": "twincat-mcp-core",
  "version": "0.3.2",
  "description": "Transport-agnostic TwinCAT ADS core runtime.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Auda29/twincat-mcp-mono.git",
    "directory": "packages/core"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ads-service": {
      "types": "./dist/ads-service.d.ts",
      "import": "./dist/ads-service.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
