    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "check": "tsc -b --pretty false",
    "test": "vitest run"
  },
  "dependencies": {
    "ads-client": "^2.2.0",
    "zod": "^3.24.2"
